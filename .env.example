CONFLUENCE_URL=https://your-domain.atlassian.net
CONFLUENCE_USERNAME=your-email@example.com
CONFLUENCE_API_TOKEN=your-api-token
CONFLUENCE_SPACES=DEV,OPS,HR
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_LLM_MODEL=mistral:7b
OLLAMA_EMBED_MODEL=nomic-embed-text
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=confluence_docs
QDRANT_SEMANTIC_CACHE_COLLECTION=semantic_cache
SQLITE_PATH=/data/app.db
API_KEY=change-me-to-a-strong-random-key
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT_RPM=30
ENVIRONMENT=production
AZURE_OPENAI_ENABLED=false
REDIS_ENABLED=false
BIFROST_ENABLED=false
LOG_LEVEL=INFO
CONVERSATION_PRUNE_DAYS=90
LOCAL_DOCS_PATH=/local_docs